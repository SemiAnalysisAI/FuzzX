+; CHECK-NEXT:    v_add_u32_e32 v0, v2, v0
+; CHECK-NEXT:    v_and_b32_e32 v0, 0xff, v0
+; CHECK-NEXT:    s_setpc_b64 s[30:31]
+entry:
+  %div = udiv i8 1, %arg
+  ret i8 %div
+}
