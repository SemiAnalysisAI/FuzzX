+; CHECK-NEXT:    v_cndmask_b32_e64 v3, 0, 1, vcc
+; CHECK-NEXT:    v_add_u32_e32 v4, 1, v3
+; CHECK-NEXT:    v_cmp_ge_u32_e32 vcc, v2, v1
+; CHECK-NEXT:    v_cndmask_b32_e32 v1, v3, v4, vcc
+; CHECK-NEXT:    v_ashrrev_i32_e32 v0, 31, v0
