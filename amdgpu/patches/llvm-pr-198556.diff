+    // Check for cross-contamination between the two recursions.
+    bool RHSStale = !Op.first && RHSSlot >= 0 &&
+                    Src[RHSSlot] != SrcBeforeRecurse[RHSSlot];
+    bool LHSStale = LHSSlot >= 0 && LHSSlot < (int)Src.size() &&
+                    Src[LHSSlot] != SrcAfterLHS[LHSSlot];
+    if (RHSStale || LHSStale) {
