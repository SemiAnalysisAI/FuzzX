diff --git a/llvm/lib/Target/AMDGPU/AMDGPUISelDAGToDAG.cpp b/llvm/lib/Target/AMDGPU/AMDGPUISelDAGToDAG.cpp
index ecf8d957fc80f..8aa2270ae95ca 100644
--- a/llvm/lib/Target/AMDGPU/AMDGPUISelDAGToDAG.cpp
+++ b/llvm/lib/Target/AMDGPU/AMDGPUISelDAGToDAG.cpp
@@ -4354,6 +4354,14 @@ static std::pair<unsigned, uint8_t> BitOp3_Op(SDValue In,
       }
       // Try to replace parent operator
       if (Src[I] == In) {
+        // If Op is already present at another slot, substituting here would
+        // create a duplicate entry. Two slots with the same value would be
+        // assigned different truth-table column bits (e.g. 0xf0 and 0xcc),
+        // corrupting all downstream bit assignments.
+        for (unsigned J = 0; J < Src.size(); ++J) {
+          if (J != I && Src[J] == Op)
+            return false;
+        }
         Bits = SrcBits[I];
         Src[I] = Op;
         return true;
