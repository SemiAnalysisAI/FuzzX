.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<6>;
    .reg .b64   %rd<3>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;

    and.b32       %r1, 32, %r0;
    cnot.b32      %r2, %r1;
    add.u32       %r3, %r2, %r0;
    sub.u32       %r4, %r0, %r3;
    setp.gt.u32   %p0, 0, %r4;
    selp.b32      %r5, 52761, 0, %p0;

    mul.wide.u32    %rd2, %r0, 16;
    add.s64         %rd1, %rd0, %rd2;
    st.global.u32   [%rd1], %r5;
    ret;
}
