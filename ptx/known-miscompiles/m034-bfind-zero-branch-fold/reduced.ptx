.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<2>;
    .reg .b32  %r<22>;
    .reg .b64  %rd<8>;

    ld.param.u64 %rd1, [out_ptr];
    mov.u32      %r20, %tid.x;
    mov.u32      %r4, 4;
    setp.ne.u32  %p0, %r20, 0;
    @%p0 bra     done;

    bfind.u32    %r16, 0;
    xor.b32      %r4, %r16, %r20;

done:
    sub.u32      %r3, %r4, 32;
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32 %rd5, %r20, 16;
    add.s64      %rd4, %rd4, %rd5;
    st.global.u32 [%rd4 + 12], %r3;
    ret;
}
