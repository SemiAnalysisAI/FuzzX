.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<5>;
    .reg .b64   %rd<3>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;

    mov.u32       %r1, 4294967294;
    setp.eq.u32   %p0, %r0, 32;
    @%p0 bra      then_path;
    bra           else_path;
then_path:
    mov.u32       %r1, 0;
    mov.u32       %r3, 0;
    bra           done;
else_path:
    brev.b32      %r2, %r1;
    sub.u32       %r3, 32, %r2;
done:
    add.u32       %r4, %r1, %r3;

    mul.wide.u32    %rd2, %r0, 16;
    add.s64         %rd1, %rd0, %rd2;
    st.global.u32   [%rd1], %r4;
    ret;
}
