    .reg .b32   %r<11>;
    .reg .b64   %rd<10>;
    .reg .f32   %f<4>;
    .reg .f64   %fd<4>;
    .local .align 16 .b8 fuzzx_local[64];
    .shared .align 16 .b8 fuzzx_shared[512];

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r3, %r0;
    mov.u32         %r4, 4;
    mov.u32         %r5, %r8;
    mov.u32         %r6, %r2;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 12;

    bra             block_0;

block_0:
    mad.hi.cc.s32 %r0, 3, %r3, %r0;
    setp.eq.u32   %p0, %r2, %r3;
    and.b32       %r10, %r0, 1023;
    cvt.rn.f32.u32 %f0, %r10;
    and.b32       %r10, %r5, 1023;
    cvt.rn.f32.u32 %f1, %r10;
    mov.f32       %f3, %f0;
    and.b32       %r10, %r2, 1023;
    cvt.rn.f32.u32 %f2, %r10;
    @!%p0 fma.rn.sat.f32 %f3, %f0, %f1, %f2;
    cvt.rzi.s32.f32 %r4, %f3;
    setp.lt.s32   %p3, %r7, %r4;
    setp.gt.u32   %p1, 27, 16;
    and.b32       %r10, %r2, 1023;
    cvt.rn.f32.u32 %f0, %r10;
    and.b32       %r10, %r2, 1023;
    cvt.rn.f32.u32 %f1, %r10;
    setp.ne.u32   %p2, 0, 0;
    @%p3 setp.ne.or.f32 %p2, %f0, %f1, %p1;
    cvta.to.global.u64 %rd6, %rd0;
    ld.global.s8  %r3, [%rd6 + 6];
    setp.eq.u32   %p5, %r9, 0;
    @%p5 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_0;
loop_done_9:
    bra             block_1;

block_1:
    bra             block_2;

block_2:
    setp.ge.u32   %p9, 29, %r5;
    cvta.to.global.u64 %rd8, %rd1;
    mul.wide.u32  %rd9, %r8, 16;
    add.s64       %rd8, %rd8, %rd9;
    @%p9 st.volatile.global.u16 [%rd8 + 6], %r6;
    @%p9 ld.volatile.global.u16 %r2, [%rd8 + 6];
    bra             exit;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
