.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<4>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r1, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r1, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r3, %r0;

    setp.le.s32   %p0, %r2, %r0;
    @%p0 bra   outer_then;
    bra             outer_else;
outer_then:
    setp.ge.u32   %p1, %r3, %r2;
    @%p1 bra   inner_then;
    bra             inner_else;
inner_then:
    mul.lo.u32    %r3, %r2, 8;
    bra             outer_done;
inner_else:
    or.b32        %r0, %r0, 345;
    bra             outer_done;
outer_else:
    shl.b32       %r0, %r2, 11;
    bra             outer_done;
outer_done:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r1, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    st.global.u32   [%rd4 + 4], %r1;
    st.global.u32   [%rd4 + 8], %r2;
    st.global.u32   [%rd4 + 12], %r3;
    ret;
}
