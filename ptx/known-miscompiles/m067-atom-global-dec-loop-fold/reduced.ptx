.version 8.8
.target sm_103
.address_size 64
.const .align 16 .b8 fuzzx_const[64] = {3,20,37,54,71,88,105,122,139,156,173,190,207,224,241,2,19,36,53,70,87,104,121,138,155,172,189,206,223,240,1,18,35,52,69,86,103,120,137,154,171,188,205,222,239,0,17,34,51,68,85,102,119,136,153,170,187,204,221,238,255,16,33,50};

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<9>;
    .reg .b16   %h<4>;
    .reg .b32   %r<11>;
    .reg .b64   %rd<10>;
    .reg .f32   %f<4>;
    .reg .f64   %fd<4>;
    .local .align 16 .b8 fuzzx_local[64];
    .shared .align 16 .b8 fuzzx_shared[512];

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r3, %r0;
    mov.u32         %r4, 4;
    mov.u32         %r5, %r8;
    mov.u32         %r6, %r2;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 10;

    bra             block_0;

block_0:
    setp.eq.u32   %p0, %r0, %r2;
    cvta.to.global.u64 %rd6, %rd0;
    @!%p0 ld.volatile.global.b32 %r1, [%rd6 + 4];
    and.b32       %r10, 29, 31;
    shl.b32       %r3, %r6, %r10;
    mov.u64       %rd6, fuzzx_shared;
    mul.wide.u32  %rd7, %r8, 16;
    add.s64       %rd6, %rd6, %rd7;
    st.shared.b16 [%rd6 + 4], %r7;
    ld.shared.b16 %r0, [%rd6 + 4];
    mov.u64       %rd6, fuzzx_const;
    ld.const.u16  %r0, [%rd6 + 50];
    setp.le.s32   %p1, %r6, 29;
    @%p1 bra   block_3;
    bra             block_1;

block_1:
    bra             block_2;

block_2:
    setp.ge.s32   %p4, 0, %r4;
    @!%p4 shr.s32  %r3, %r7, 13;
    setp.le.u32   %p5, %r3, %r6;
    @%p5 bra   block_3;
    bra             block_3;

block_3:
    cvta.to.global.u64 %rd8, %rd1;
    mul.wide.u32  %rd9, %r8, 16;
    add.s64       %rd8, %rd8, %rd9;
    st.global.u32 [%rd8 + 12], %r6;
    mov.u32       %r10, %r0;
    atom.global.dec.u32 %r7, [%rd8 + 12], %r10;
    ld.global.u32 %r10, [%rd8 + 12];
    add.u32       %r7, %r7, %r10;
    setp.eq.u32   %p6, %r9, 0;
    @%p6 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_1;
loop_done_9:
    bra             block_4;

block_4:
    setp.le.s32   %p7, 0, %r3;
    @!%p7 shr.u32  %r1, %r0, 0;
    bra             exit;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    st.global.u32   [%rd4 + 4], %r1;
    ret;
}
