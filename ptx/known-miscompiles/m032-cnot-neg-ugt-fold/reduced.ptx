.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<1>;
    .reg .b32  %r<4>;
    .reg .b64  %rd<3>;

    ld.param.u64 %rd0, [out_ptr];
    mov.u32      %r0, %tid.x;
    cnot.b32     %r1, %r0;
    neg.s32      %r1, %r1;
    setp.gt.u32  %p0, 0, %r1;
    selp.b32     %r2, 1, 2, %p0;

    cvta.to.global.u64 %rd0, %rd0;
    mul.wide.u32 %rd1, %r0, 16;
    add.s64      %rd2, %rd0, %rd1;
    st.global.u32 [%rd2], %r2;
    ret;
}
