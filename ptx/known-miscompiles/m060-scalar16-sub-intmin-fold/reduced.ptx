.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<1>;
    .reg .b16  %h<3>;
    .reg .b32  %r<5>;
    .reg .b64  %rd<3>;

    ld.param.u64 %rd0, [out_ptr];
    mov.u32      %r0, %tid.x;
    mov.u32      %r1, %lanemask_gt;

    setp.ne.u32  %p0, 0, 0;
    cvt.s16.s32  %h0, 0;
    cvt.s16.s32  %h1, %r1;
    @!%p0 sub.s16 %h2, %h0, %h1;
    @!%p0 cvt.s32.s16 %r2, %h2;
    and.b32      %r3, %r2, 0x59d96384;

    cvta.to.global.u64 %rd1, %rd0;
    mul.wide.u32 %rd2, %r0, 16;
    add.s64      %rd1, %rd1, %rd2;
    st.global.u32 [%rd1 + 0], %r2;
    st.global.u32 [%rd1 + 4], %r3;
    st.global.u32 [%rd1 + 8], 0;
    st.global.u32 [%rd1 + 12], 0;
    ret;
}
