.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr,
    .param .u32 n
)
{
    .reg .pred %p<1>;
    .reg .b32 %r<8>;
    .reg .b64 %rd<3>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [n];
    mov.u32 %r2, %tid.x;
    mov.u32 %r1, %r2;
    mov.u32 %r3, %r0;
    mov.u32 %r4, 4;
    mov.u32 %r5, %r2;
    mov.u32 %r7, %r0;
    setp.ne.u32 %p0, %r4, %r1;
    @%p0 bra then;
    bra else;
then:
    bra done;
else:
    not.b32 %r6, %r5;
    xor.b32 %r0, %r7, %r6;
    bra done;
done:
    mad.lo.u32 %r1, 594, %r3, %r0;
    cvta.to.global.u64 %rd0, %rd0;
    mul.wide.u32 %rd1, %r2, 4;
    add.s64 %rd2, %rd0, %rd1;
    st.global.u32 [%rd2], %r1;
    ret;
}
