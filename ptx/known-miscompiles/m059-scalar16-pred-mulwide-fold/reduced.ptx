.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<1>;
    .reg .b16  %h<3>;
    .reg .b32  %r<6>;
    .reg .b64  %rd<5>;

    ld.param.u64 %rd0, [in_ptr];
    ld.param.u64 %rd1, [out_ptr];
    ld.param.u32 %r0, [in_n];
    mov.u32      %r1, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32 %rd3, %r1, 4;
    add.s64      %rd2, %rd2, %rd3;
    ld.global.u32 %r2, [%rd2];

    cvt.s16.s32  %h0, %r0;
    cvt.s16.s32  %h1, 0;
    max.s16      %h2, %h0, %h1;
    cvt.s32.s16  %r3, %h2;
    setp.eq.u32  %p0, 0, %r3;
    cvt.u16.u32  %h0, %r2;
    cvt.u16.u32  %h1, 38971;
    @!%p0 mul.wide.u16 %r0, %h0, %h1;

    cvta.to.global.u64 %rd2, %rd1;
    mul.wide.u32 %rd4, %r1, 16;
    add.s64      %rd2, %rd2, %rd4;
    st.global.u32 [%rd2 + 0], %r0;
    st.global.u32 [%rd2 + 4], 0;
    st.global.u32 [%rd2 + 8], 0;
    st.global.u32 [%rd2 + 12], 0;
    ret;
}
