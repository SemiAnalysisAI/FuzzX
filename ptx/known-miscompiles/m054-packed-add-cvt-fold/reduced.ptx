.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<8>;
    .reg .b64   %rd<6>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r1, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r1, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];

    mov.u32         %r3, 4;
    add.s16x2       %r4, %r3, %r2;
    cvt.u32.u16     %r5, %r4;
    add.s16x2       %r0, %r5, %r2;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r1, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    ret;
}
