.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<18>;
    .reg .b32   %r<13>;
    .reg .b64   %rd<10>;
    ld.param.u32    %r0, [in_n];
    mov.u32         %r3, %r0;
    mov.u32         %r4, 4;
    mov.b32         %r2, 0x40003c00;
    cvt.s64.s32   %rd6, %r4;
    bfe.s64       %rd6, %rd6, 56, 60;
    mov.b64       {%r5, %r9}, %rd6;
    setp.gt.u32   %p7, 18, %r2;
    @!%p7 shl.b32  %r0, %r3, 9;
    add.cc.u32    %r6, %r5, 0;
    addc.u32      %r0, %r0, %r7;
    st.global.u32   [%rd4 + 0], %r0;
}
