.version 8.8
.target sm_103
.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<8>;
    .reg .b64   %rd<6>;

    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r0, %tid.x;
    mov.u32         %r1, 0;
    mov.u32         %r2, 0;

    setp.lt.u32   %p0, %r0, 32;
    @%p0 bra      structured_if_0_then;
    bra           structured_if_0_else;
structured_if_0_then:
    popc.b32      %r3, 2052987616;
    popc.b32      %r2, %r3;
    add.u32       %r4, %r0, 32;
    @%p0 bra      structured_if_1_then;
    bra           structured_if_1_else;
structured_if_1_then:
    add.u32       %r5, 2147483646, %r2;
    sub.u32       %r6, 3046743225, %r5;
    and.b32       %r1, %r6, %r4;
structured_if_1_else:
structured_if_0_else:
    add.u32       %r7, %r1, %r2;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r0, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r7;
    ret;
}
