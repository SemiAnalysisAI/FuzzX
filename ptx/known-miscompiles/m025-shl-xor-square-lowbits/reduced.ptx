.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32 %r<7>;
    .reg .b64 %rd<2>;

    ld.param.u64 %rd1, [out_ptr];
    ld.param.u32 %r0, [in_n];

    shl.b32    %r4, %r0, 8;
    xor.b32    %r4, 8, %r4;
    shl.b32    %r2, %r4, 14;
    mul.lo.u32 %r1, %r2, %r2;
    and.b32    %r6, 7, %r1;

    st.global.u32 [%rd1], %r6;
    ret;
}
