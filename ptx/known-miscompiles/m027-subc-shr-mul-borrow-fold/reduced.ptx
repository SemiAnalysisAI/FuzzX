.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32 %r<4>;
    .reg .b64 %rd<1>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [in_n];
    shr.u32 %r1, %r0, 9;
    mul.lo.u32 %r1, %r1, 3;
    mov.u32 %r0, 4026531840;
    sub.cc.u32 %r2, %r0, %r1;
    subc.u32 %r3, %r0, 31;
    st.global.u32 [%rd0], %r3;
    ret;
}
