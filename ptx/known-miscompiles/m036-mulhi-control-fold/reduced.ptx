.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<22>;
    .reg .b32   %r<20>;
    .reg .b64   %rd<5>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    cvta.to.global.u64 %rd2, %rd0;
    ld.global.u32   %r2, [%rd2];

    mov.u32         %r5, 0xffd2cb88;
    mad.lo.u32      %r6, %r0, %r5, %r5;
    setp.ge.u32     %p6, 19682, %r2;
    @!%p6 bra       structured_if_1_else;
    clz.b32         %r8, 0;
    bra             structured_if_1_done;
structured_if_1_else:
    mad.lo.u32      %r1, %r5, %r6, 31152;
    shr.u32         %r15, %r1, 26;
    setp.ge.u32     %p14, %r15, 8;
    selp.b32        %r0, %r1, 1073741824, %p14;
    mov.u32         %r8, 4;
    xor.b32         %r16, %r0, 33145;
    mul.hi.s32      %r4, 6, %r16;
    setp.eq.u32     %p18, %r4, 0;
    @%p18 bra       structured_if_2_done;
    mad.lo.u32      %r14, %r8, 536870912, 0xffffffff;
    sub.u32         %r19, %r4, %r14;
    add.u32         %r1, %r19, 144;
structured_if_2_done:
structured_if_1_done:
    setp.le.u32     %p21, %r8, %r19;
    @%p21 bra       structured_if_3_done;
    mov.u32         %r1, 0;
structured_if_3_done:

    st.global.u32   [%rd1 + 4], %r1;
    ret;
}
