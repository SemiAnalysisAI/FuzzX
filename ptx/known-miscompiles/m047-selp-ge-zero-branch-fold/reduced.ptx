.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<3>;
    .reg .b64   %rd<3>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;
    mov.u32         %r2, 0;

    setp.ne.u32     %p0, 32, %r0;
    selp.b32        %r1, 4294967295, 0, %p0;
    setp.ge.u32     %p1, %r1, 0;
    @%p1 bra        then_path;
    bra             done;

then_path:
    mov.u32         %r2, 27;

done:
    mul.wide.u32    %rd2, %r0, 16;
    add.s64         %rd1, %rd0, %rd2;
    st.global.u32   [%rd1 + 8], %r2;
    ret;
}
