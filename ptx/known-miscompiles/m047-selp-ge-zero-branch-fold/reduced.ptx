.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 dummy_ptr,
    .param .u64 out_ptr
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<1>;
    .reg .b64   %rd<1>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;

    setp.ne.u32     %p0, 32, %r0;
    selp.b32        %r0, 4294967295, 0, %p0;
    setp.ge.u32     %p0, %r0, 0;
    @!%p0 bra       done;
    st.global.u32   [%rd0], 27;

done:
    ret;
}
