.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32 %r<10>;
    .reg .b64 %rd<2>;

    ld.param.u64    %rd0, [out_ptr];
    ld.param.u32    %r3, [in_n];

    cnot.b32        %r5, %r3;
    shl.b32         %r9, %r5, 12;
    sub.cc.u32      %r4, 3285, %r9;
    subc.u32        %r9, 939, 433;

    cvta.to.global.u64 %rd1, %rd0;
    st.global.u32   [%rd1], %r9;
    ret;
}
