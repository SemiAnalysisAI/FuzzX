.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<2>;
    .reg .b64   %rd<1>;

    ld.param.u64    %rd0, [out_ptr];
    st.global.u32   [%rd0], 0;
    mov.u32         %r0, 1;

loop:
    setp.eq.u32     %p0, %r0, 0;
    @%p0 bra        done;
    sub.u32         %r0, %r0, 1;

    set.eq.u32.u32  %r1, %r0, 0;
    setp.ne.u32     %p0, %r1, 1;
    @%p0 bra        loop;
    st.global.u32   [%rd0], 1;
    bra             loop;

done:
    ret;
}
