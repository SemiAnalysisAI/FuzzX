.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<14>;
    .reg .b16   %h<4>;
    .reg .b32   %r<13>;
    .reg .b64   %rd<10>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r3, %r0;
    mov.u32         %r6, %r2;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 12;
    mov.u32         %r10, 12;
    mov.u32         %r11, 8;

    bra             block_0;

block_0:
    and.b32       %r12, %r1, 31;
    shr.s32       %r1, %r7, %r12;
    setp.eq.u32   %p2, %r9, 0;
    @%p2 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_0;
loop_done_9:
    bra             block_1;

block_1:
    mov.u32       %r7, 1;
    setp.lt.u32   %p6, %r1, %r3;
    @%p6 bra   block_4;
    bra             block_2;

block_2:
    cvt.u16.u32   %h0, %r6;
    cvt.s32.s16   %r6, %h0;
    setp.le.u32   %p10, 128, %r1;
    cvta.to.global.u64 %rd6, %rd0;
    @%p10 ld.global.u8 %r0, [%rd6 + 15];
    mad.lo.s32    %r7, %r6, 2, %r2;
    setp.eq.u32   %p11, %r10, 0;
    @%p11 bra   loop_done_10;
    sub.u32         %r10, %r10, 1;
    bra             block_0;
loop_done_10:
    bra             block_3;

block_3:
    cvta.to.global.u64 %rd8, %rd1;
    mul.wide.u32  %rd9, %r8, 16;
    add.s64       %rd8, %rd8, %rd9;
    st.global.u32 [%rd8 + 8], %r0;
    bra             block_4;

block_4:
    mov.u32       %r1, 0;
    setp.eq.u32   %p13, %r11, 0;
    @%p13 bra   loop_done_11;
    sub.u32         %r11, %r11, 1;
    bra             block_1;
loop_done_11:
    bra             block_5;

block_5:
    mad.lo.s32    %r5, %r0, %r7, %r6;
    mov.u32       %r0, %r5;
    bra             exit;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    ret;
}
