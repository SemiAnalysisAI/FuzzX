.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<18>;
    .reg .b16   %h<4>;
    .reg .b32   %r<13>;
    .reg .b64   %rd<10>;
    .reg .f64   %fd<4>;
    .shared .align 16 .b8 fuzzx_shared[512];
