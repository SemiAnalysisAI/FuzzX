.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<7>;
    .reg .b64   %rd<4>;

    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r1, %tid.x;
    mov.u32         %r4, 1;
    mov.u32         %r6, 1;

pre_loop:
    setp.eq.u32   %p0, %r4, 0;
    @%p0 bra   pre_done;
    sub.u32         %r4, %r4, 1;
    bra             pre_loop;
pre_done:
    mov.u32         %r3, 2147483647;

neg_loop:
    setp.eq.u32   %p1, %r6, 0;
    @%p1 bra   done;
    sub.u32         %r6, %r6, 1;
    neg.s32       %r3, %r3;
    bra             neg_loop;

done:
    cvta.to.global.u64 %rd1, %rd1;
    mul.wide.u32    %rd2, %r1, 16;
    add.s64         %rd3, %rd1, %rd2;
    st.global.u32   [%rd3 + 0], %r3;
    ret;
}
