.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<1>;
    .reg .b32  %r<4>;
    .reg .b64  %rd<3>;

    ld.param.u64 %rd0, [out_ptr];
    mov.u32      %r0, %tid.x;

    mul.hi.u32   %r1, 2, %r0;
    not.b32      %r2, %r1;
    mov.u32      %r3, 123;
    setp.ne.u32  %p0, %r1, 0;
    @%p0 bra     exit;
    clz.b32      %r3, %r2;

exit:
    cvta.to.global.u64 %rd0, %rd0;
    mul.wide.u32 %rd1, %r0, 16;
    add.s64      %rd2, %rd0, %rd1;
    st.global.u32 [%rd2], %r3;
    ret;
}
