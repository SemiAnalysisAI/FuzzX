.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32   %r<19>;
    .reg .b64   %rd<2>;

    ld.param.u64    %rd1, [out_ptr];

    bmsk.clamp.b32 %r10, 17, 26;
    clz.b32       %r2, %r10;
    shr.u32       %r4, %r2, 24;
    bfi.b32       %r5, %r4, 8388608, 28, 26;
    mad.lo.u32    %r18, %r5, %r5, 3370615734;
    or.b32        %r6, 524288, %r18;
    and.b32       %r2, %r6, 23383;

    st.global.u32   [%rd1 + 8], %r2;
    ret;
}
