.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<8>;
    .reg .b64   %rd<4>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;
    mov.u32         %r1, 16;
    mov.u32         %r2, 32;
    mov.u32         %r3, 0;
    mov.u32         %r4, 4;

    setp.ne.u32     %p0, %r0, 19;
    @%p0 bra        exit_block;
    setp.eq.u32     %p1, 27, %r3;
    @!%p1 add.u16x2 %r4, %r2, %r0;

exit_block:
    add.u32         %r5, %r1, %r4;
    cvta.to.global.u64 %rd1, %rd0;
    mul.wide.u32    %rd2, %r0, 16;
    add.s64         %rd3, %rd1, %rd2;
    st.global.u32   [%rd3 + 12], %r5;
    ret;
}
