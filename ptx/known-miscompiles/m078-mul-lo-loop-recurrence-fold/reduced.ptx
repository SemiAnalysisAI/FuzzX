.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<12>;
    .reg .b32   %r<12>;
    .reg .b64   %rd<10>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 2;
    mov.u32         %r10, 5;

    bra             block_0;

block_0:
    setp.gt.s32   %p1, 4294901760, %r2;
    @%p1 bra   block_4;
    bra             block_3;

block_3:
    mad.lo.u32    %r2, %r2, %r7, %r1;
    setp.eq.u32   %p8, %r9, 0;
    @%p8 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_3;
loop_done_9:
    bra             block_4;

block_4:
    or.b32        %r1, 32, %r2;
    setp.eq.u32   %p10, %r10, 0;
    @%p10 bra   exit;
    sub.u32         %r10, %r10, 1;
    bra             block_3;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    st.global.u32   [%rd4 + 4], %r1;
    ret;
}
