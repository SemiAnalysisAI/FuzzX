.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<6>;
    .reg .b64   %rd<4>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;

    or.b32          %r1, %r0, 0xbb7dffd2;
    shr.s32         %r1, %r1, 3;
    mov.u32         %r2, 0xc0000000;
    setp.ge.u32     %p0, %r2, %r1;
    selp.b32        %r3, 986, 123, %p0;

    cvta.to.global.u64 %rd1, %rd0;
    st.global.u32   [%rd1], %r3;
    ret;
}
