.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b16   %h<4>;
    .reg .b32   %r<10>;
    .reg .b64   %rd<10>;

    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r8, %tid.x;
    add.u32         %r3, %r8, 32768;
    cvt.s16.s32     %h0, %r3;
    neg.s16         %h2, %h0;
    cvt.s32.s16     %r6, %h2;
    add.u32         %r0, %r6, %r3;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    ret;
}
