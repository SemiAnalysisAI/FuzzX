.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32   %r<34>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r32, %tid.x;

    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r32, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r10, [%rd2];

    add.u32       %r12, %r32, 16;
    cvt.u64.u32   %rd6, 262144;
    cvt.u64.u32   %rd7, 267548771;
    or.b64        %rd6, %rd6, %rd7;
    mov.b64       {%r1, %r33}, %rd6;
    sub.u32       %r12, 0, %r12;
    shl.b32       %r22, %r1, 19;
    shr.u32       %r1, %r12, 13;
    add.u32       %r5, %r22, %r1;
    add.u32       %r21, %r5, %r1;
    and.b32       %r11, %r21, %r10;
    sub.u32       %r6, %r11, 15029;
    sub.u32       %r19, %r6, 32;
    add.u32       %r1, %r22, %r19;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r32, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 4], %r1;
    ret;
}
