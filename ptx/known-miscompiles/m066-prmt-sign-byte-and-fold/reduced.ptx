.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32   %r<13>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r3, %r0;

    prmt.b32      %r1, %r2, %r3, 0x83c9;
    and.b32       %r0, %r1, 255;
    add.u32       %r0, %r0, 1;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32  %rd5, %r8, 16;
    add.s64       %rd4, %rd4, %rd5;
    st.global.u32 [%rd4 + 0], %r0;
    ret;
}
