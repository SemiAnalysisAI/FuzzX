    .reg .f32   %f<4>;
    .reg .f64   %fd<4>;
    .local .align 16 .b8 fuzzx_local[64];
    .shared .align 16 .b8 fuzzx_shared[512];

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r3, %r0;
    mov.u32         %r4, 4;
    mov.u32         %r5, %r8;
    mov.u32         %r6, %r2;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 14;

    bra             block_0;

block_0:
    setp.gt.u32   %p0, %r6, %r1;
    mov.u64       %rd6, fuzzx_shared;
    mul.wide.u32  %rd7, %r8, 16;
    add.s64       %rd6, %rd6, %rd7;
    mov.b64       %rd7, {%r1, %r1};
    @!%p0 st.shared.u64 [%rd6 + 8], %rd7;
    @!%p0 ld.shared.s64 %rd7, [%rd6 + 8];
    @!%p0 mov.b64 {%r3, %r10}, %rd7;
    setp.le.s32   %p1, %r0, %r2;
    @%p1 bra   block_2;
    bra             block_1;

block_1:
    lop3.b32      %r0, 1, %r5, %r0, 0x3e;
    mov.u64       %rd6, fuzzx_const;
    ld.const.v2.u64   {%rd4, %rd5}, [%rd6 + 16];
    mov.b64       {%r6, %r10}, %rd4;
    mov.b64       {%r5, %r10}, %rd5;
    setp.le.s32   %p3, 18, 0;
    cvta.to.global.u64 %rd6, %rd0;
    @!%p3 ld.volatile.global.v4.u32 {%r5, %r4, %r6, %r7}, [%rd6 + 96];
    bra             block_2;

block_2:
    setp.eq.u32   %p4, 32768, 2528071068;
    and.b32       %r10, 15, 1023;
    cvt.rn.f32.u32 %f0, %r10;
    and.b32       %r10, %r2, 1023;
    cvt.rn.f32.u32 %f1, %r10;
    @!%p4 set.eq.u32.f32 %r7, %f0, %f1;
    setp.eq.u32   %p6, %r9, 0;
    @%p6 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_1;
loop_done_9:
    bra             block_3;

block_3:
    bra             exit;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
