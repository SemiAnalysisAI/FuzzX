.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32   %r<8>;
    .reg .b64   %rd<6>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r1, %tid.x;
    mov.u32         %r2, 28;
    add.u16x2       %r3, %r2, %r0;
    cvt.s32.s16     %r4, %r3;
    add.u32         %r5, %r0, %r4;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r1, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 4], %r5;
    ret;
}
