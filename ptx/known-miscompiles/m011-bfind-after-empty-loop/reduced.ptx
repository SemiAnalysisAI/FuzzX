.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<6>;
    .reg .b64   %rd<4>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r1, %tid.x;
    mov.u32         %r2, 1;
    mov.u32         %r3, 4;
    mov.u32         %r0, 0;

pre_loop:
    setp.eq.u32   %p0, %r2, 0;
    @%p0 bra      bfind_loop;
    sub.u32       %r2, %r2, 1;
    bra           pre_loop;

bfind_loop:
    setp.eq.u32   %p1, %r3, 0;
    @%p1 bra      done;
    sub.u32       %r3, %r3, 1;
    bfind.u32     %r4, 0;
    mov.u32       %r0, 0x7fffffff;
    bra           bfind_loop;

done:
    sub.u32       %r5, %r4, %r0;
    cvta.to.global.u64 %rd1, %rd0;
    mul.wide.u32  %rd2, %r1, 16;
    add.s64       %rd3, %rd1, %rd2;
    st.global.u32 [%rd3 + 0], %r5;
    ret;
}
