.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<2>;
    .reg .b32  %r<22>;
    .reg .b64  %rd<8>;

    ld.param.u64 %rd1, [out_ptr];
    mov.u32      %r20, %tid.x;
    setp.ne.u32  %p0, %r20, 20;
    @%p0 bra     exit;

    not.b32      %r13, %r20;
    xor.b32      %r4, %r13, 0x9033a9b3;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32 %rd5, %r20, 16;
    add.s64      %rd4, %rd4, %rd5;
    st.global.u32 [%rd4 + 12], %r4;

exit:
    ret;
}
