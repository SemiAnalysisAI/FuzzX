.version 8.8
.target sm_103
.address_size 64
.const .align 16 .b8 fuzzx_const[64] = {3,20,37,54,71,88,105,122,139,156,173,190,207,224,241,2,19,36,53,70,87,104,121,138,155,172,189,206,223,240,1,18,35,52,69,86,103,120,137,154,171,188,205,222,239,0,17,34,51,68,85,102,119,136,153,170,187,204,221,238,255,16,33,50};

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<13>;
    .reg .b16   %h<4>;
    .reg .b32   %r<11>;
    .reg .b64   %rd<10>;
    .reg .f32   %f<4>;
    .reg .f64   %fd<4>;
    .local .align 16 .b8 fuzzx_local[64];
    .shared .align 16 .b8 fuzzx_shared[512];

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r3, %r0;
    mov.u32         %r4, 4;
    mov.u32         %r5, %r8;
    mov.u32         %r6, %r2;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 4;

    bra             block_0;

block_0:
    cvta.to.global.u64 %rd6, %rd0;
    ld.volatile.global.b8 %r4, [%rd6 + 74];
    and.b32       %r4, %r4, 255;
    setp.eq.u32   %p3, %r4, %r4;
    @%p3 bra   block_2;
    bra             block_4;

block_1:
    bra             block_4;

block_2:
    setp.le.s32   %p6, %r4, %r2;
    @%p6 bra   block_4;
    bra             block_3;

block_3:
    setp.ne.u32   %p7, 10, %r3;
    @%p7 mad.lo.u32 %r5, %r0, %r1, %r2;
    bra             block_4;

block_4:
    setp.eq.u32   %p9, %r9, 0;
    @%p9 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_3;
loop_done_9:
    bra             block_5;

block_5:
    setp.ge.u32   %p10, %r5, %r5;
    and.b32       %r10, %r3, 31;
    @!%p10 shl.b32  %r4, %r2, %r10;
    setp.lt.u32   %p11, %r5, %r3;
    @!%p11 mov.u32 %r1, %lanemask_gt;
    bra             exit;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    st.global.u32   [%rd4 + 4], %r1;
    ret;
}
