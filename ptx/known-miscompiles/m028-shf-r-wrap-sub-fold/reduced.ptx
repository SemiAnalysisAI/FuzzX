.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32 %r<4>;
    .reg .b64 %rd<1>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [in_n];
    sub.u32 %r1, 0, %r0;
    mov.u32 %r2, 0;
    shf.r.wrap.b32 %r2, %r1, %r2, 19;
    sub.u32 %r3, %r2, 1431655765;
    st.global.u32 [%rd0], %r3;
    ret;
}
