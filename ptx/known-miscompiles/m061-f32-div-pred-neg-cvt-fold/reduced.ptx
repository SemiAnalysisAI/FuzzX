.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<18>;
    .reg .b64   %rd<6>;
    .reg .f32   %f<4>;
    .reg .f64   %fd<2>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r16, %tid.x;

    mov.u32         %r1, 0;
    mov.u32         %r4, 33;
    and.b32         %r17, %r4, 1023;
    cvt.rn.f32.u32 %f0, %r17;
    and.b32         %r17, 64544, 1023;
    add.u32         %r17, %r17, 1;
    cvt.rn.f32.u32 %f1, %r17;
    div.approx.ftz.f32 %f3, %f0, %f1;
    cvt.rzi.s32.f32 %r15, %f3;

    setp.eq.u32     %p0, 0, 0;
    and.b32         %r17, %r15, 1023;
    cvt.rn.f32.u32 %f0, %r17;
    mov.f32         %f1, %f0;
    @!%p0 neg.f32   %f1, %f0;
    cvt.rzi.s32.f32 %r5, %f1;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r16, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 4], %r5;
    ret;
}
