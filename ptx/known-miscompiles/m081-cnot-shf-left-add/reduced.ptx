.version 8.8
.target sm_103
.address_size 64
.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32 %r<5>;
    .reg .b64 %rd<3>;

    ld.param.u64 %rd0, [out_ptr];
    mov.u32 %r0, %tid.x;
    mov.u32 %r1, %tid.x;
    cnot.b32 %r2, %r1;
    shf.l.wrap.b32 %r3, %r2, %r1, 18;
    add.u32 %r4, %r3, %r1;

    mul.wide.u32 %rd1, %r0, 16;
    add.s64 %rd2, %rd0, %rd1;
    st.global.u32 [%rd2], %r4;
    ret;
}
