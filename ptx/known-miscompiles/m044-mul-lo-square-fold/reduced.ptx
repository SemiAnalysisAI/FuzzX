.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32   %r<2>;
    .reg .b64   %rd<3>;

    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;

    mad.lo.u32    %r1, 4, %r0, 2;
    mul.lo.u32    %r1, %r1, 65536;
    mul.lo.u32    %r1, %r1, %r1;
    mul.lo.u32    %r1, %r1, 536870912;

    cvta.to.global.u64 %rd1, %rd0;
    mul.wide.u32    %rd2, %r0, 16;
    add.s64         %rd1, %rd1, %rd2;
    st.global.u32   [%rd1 + 4], %r1;
    ret;
}
