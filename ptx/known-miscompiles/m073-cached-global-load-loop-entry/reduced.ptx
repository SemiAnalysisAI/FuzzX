block_4:
    setp.gt.s32   %p12, %r6, 29;
    mov.u64       %rd6, fuzzx_local;
    @%p12 st.local.b16 [%rd6 + 0], %r5;
    @%p12 ld.local.b16 %r0, [%rd6 + 0];
