block_0:
    setp.gt.u32   %p0, %r2, 2;
    and.b32       %r10, %r3, 1023;
    cvt.rn.f32.u32 %f0, %r10;
    and.b32       %r10, 7, 1023;
    cvt.rn.f32.u32 %f1, %r10;
    mov.f32       %f3, %f0;
    @%p0 sub.rn.sat.f32 %f3, %f0, %f1;
    cvt.rzi.s32.f32 %r0, %f3;
    setp.gt.u32   %p1, %r1, %r0;
    @%p1 bra   block_3;
    bra             block_2;

block_1:
    setp.lt.s32   %p4, %r6, 22;
    cvta.to.global.u64 %rd6, %rd0;
    @%p4 ld.volatile.global.b32 %r1, [%rd6 + 8];
    bra             block_2;

block_2:
    mov.b32       %f0, %r6;
    testp.subnormal.f32 %p5, %f0;
    setp.ge.u32   %p7, %r5, %r3;
    cvta.to.global.u64 %rd6, %rd0;
    @!%p7 ld.global.lu.u16 %r3, [%rd6 + 54];
    cvta.to.global.u64 %rd6, %rd0;
    ld.global.cg.b16 %r1, [%rd6 + 64];
    and.b32       %r1, %r1, 65535;
