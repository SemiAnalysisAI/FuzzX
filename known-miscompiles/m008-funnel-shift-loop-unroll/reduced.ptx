.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr
)
{
    .reg .pred  %p<1>;
    .reg .b32   %r<14>;
    .reg .b64   %rd<4>;

    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r0, 32;
    mov.u32         %r1, %tid.x;
    mov.u32         %r9, %r1;
    mov.u32         %r11, %r0;
    mov.u32         %r13, 6;

loop_header:
    setp.eq.u32   %p0, %r13, 0;
    @%p0 bra   loop_done;
    sub.u32         %r13, %r13, 1;
    sub.u32       %r8, 0, %r0;
    and.b32       %r10, %r11, %r9;
    mad.lo.u32    %r11, %r11, %r10, %r11;
    xor.b32       %r0, %r10, 4096;
    shf.r.wrap.b32 %r3, %r8, 469, 9;
    add.u32       %r9, %r3, 4;
    bra             loop_header;
loop_done:
    cvta.to.global.u64 %rd1, %rd1;
    mul.wide.u32    %rd2, %r1, 16;
    add.s64         %rd3, %rd1, %rd2;
    st.global.u32   [%rd3 + 0], %r0;
    ret;
}
