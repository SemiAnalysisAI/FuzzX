.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<1>;
    .reg .b32  %r<3>;
    .reg .b64  %rd<3>;

    ld.param.u64 %rd0, [out_ptr];
    mov.u32      %r0, %tid.x;
    mov.u32      %r1, 1;
    setp.ne.u32  %p0, 32, %r0;
    @!%p0 bra    exit;
    sub.u32      %r2, 2147483648, %r1;
    sub.u32      %r1, %r1, %r2;

exit:
    cvta.to.global.u64 %rd0, %rd0;
    mul.wide.u32 %rd1, %r0, 16;
    add.s64      %rd2, %rd0, %rd1;
    st.global.u32 [%rd2], %r1;
    ret;
}
