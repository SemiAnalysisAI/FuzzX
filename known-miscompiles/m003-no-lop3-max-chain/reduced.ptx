.version 8.8
.target sm_103
.address_size 64

.entry fuzz_kernel(.param .u64 out_ptr, .param .u32 n)
{
    .reg .b32 %r<3>;
    .reg .b64 %rd<1>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [n];
    mov.u32 %r1, 0;
    sub.u32 %r2, %r0, %r0;
    max.s32 %r1, %r2, %r1;
    sub.u32 %r2, %r2, %r0;
    max.s32 %r1, %r2, %r1;
    sub.u32 %r2, %r2, %r0;
    max.s32 %r1, %r2, %r1;
    sub.u32 %r2, %r2, %r0;
    max.s32 %r1, %r2, %r1;

    st.global.u32 [%rd0], %r1;
    ret;
}
