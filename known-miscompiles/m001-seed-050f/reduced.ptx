.version 7.0
.target sm_80
.entry fuzz_kernel(.param .u64 out_ptr) {
    .reg .pred  %p0;
    .reg .b32   %r0, %r1;
    .reg .b64   %rd0;
    ld.param.u64    %rd0, [out_ptr];
    mov.u32         %r0, %tid.x;
    mad.wide.u32    %rd0, %r0, 4, %rd0;
    setp.eq.u32   %p0, %r0, 0;
    mov.u32         %r0, 1;
    mov.u32       %r1, 1;
    @%p0 bra   block_5;
block_2:
    mov.u32       %r1, 0;
block_5:
    setp.eq.u32   %p0, %r0, 0;
    @%p0 bra   done;
    mov.u32         %r0, 0;
    bra             block_2;
done:
    st.global.u32   [%rd0], %r1;
    ret;
}
