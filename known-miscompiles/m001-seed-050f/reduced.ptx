.version 7.0
.target sm_80
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred  %p<10>;
    .reg .b32   %r<11>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    ld.param.u32    %r0, [in_n];
    mov.u32         %r8, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r8, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];
    mov.u32         %r1, %r8;
    mov.u32         %r3, %r0;
    mov.u32         %r4, 4;
    mov.u32         %r5, %r8;
    mov.u32         %r6, %r2;
    mov.u32         %r7, %r0;
    mov.u32         %r9, 0;
    mov.u32         %r10, 2;

    bra             block_0;

block_0:
    xor.b32       %r2, %r0, %r4;
    not.b32       %r0, %r6;
    shl.b32       %r0, %r4, 22;
    sub.u32       %r0, %r2, 17;
    setp.le.u32   %p0, %r5, %r0;
    @%p0 bra   block_5;
    bra             block_3;

block_1:
    shr.u32       %r4, %r5, 15;
    or.b32        %r6, %r7, %r3;
    setp.gt.u32   %p1, %r1, 32;
    @%p1 bra   block_6;
    bra             block_3;

block_2:
    setp.ne.u32   %p2, %r3, %r7;
    selp.b32      %r2, %r0, %r2, %p2;
    add.u32       %r3, %r5, %r4;
    add.u32       %r7, 7, %r4;
    shr.u32       %r6, %r3, 9;
    setp.gt.u32   %p3, %r2, %r1;
    selp.b32      %r0, 27, %r0, %p3;
    add.u32       %r2, %r4, %r0;
    bra             block_4;

block_3:
    shr.u32       %r4, %r4, 19;
    or.b32        %r2, 3, %r2;
    xor.b32       %r4, %r7, %r2;
    bra             block_4;

block_4:
    min.u32       %r1, 26, %r3;
    shr.u32       %r7, %r7, 22;
    setp.ne.u32   %p4, %r5, %r1;
    selp.b32      %r5, %r1, 19, %p4;
    add.u32       %r3, %r1, %r2;
    xor.b32       %r3, %r2, %r6;
    not.b32       %r0, 6;
    setp.eq.u32   %p5, %r9, 0;
    @%p5 bra   loop_done_9;
    sub.u32         %r9, %r9, 1;
    bra             block_3;
loop_done_9:
    bra             block_5;

block_5:
    or.b32        %r4, 22, %r5;
    setp.ge.u32   %p6, %r4, %r7;
    selp.b32      %r4, %r7, %r2, %p6;
    max.u32       %r7, %r6, %r3;
    min.u32       %r1, %r4, %r5;
    mul.hi.u32    %r0, 24, %r1;
    not.b32       %r6, %r4;
    setp.eq.u32   %p7, %r10, 0;
    @%p7 bra   loop_done_10;
    sub.u32         %r10, %r10, 1;
    bra             block_2;
loop_done_10:
    bra             block_6;

block_6:
    mul.lo.u32    %r5, 21, %r6;
    max.u32       %r1, %r5, %r6;
    mul.hi.u32    %r1, %r3, 0;
    setp.ge.u32   %p8, %r3, %r2;
    selp.b32      %r3, %r0, %r3, %p8;
    setp.le.u32   %p9, %r3, %r0;
    selp.b32      %r2, %r5, %r6, %p9;
    sub.u32       %r4, %r3, %r1;
    bra             exit;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    st.global.u32   [%rd4 + 8], %r2;
}