.version 8.8
.target sm_103
.address_size 64

.entry fuzz_kernel(.param .u64 in_ptr, .param .u64 out_ptr, .param .u32 n)
{
    .reg .b32 %r<10>;
    .reg .b64 %rd<4>;

    ld.param.u64 %rd1, [out_ptr];
    ld.param.u32 %r0, [n];

    mad.lo.u32  %r4, 1680, %r0, 0;
    mov.u32     %r9, 357;
    mov.u32     %r7, 0x6000;
    mad.lo.u32  %r9, %r9, %r7, %r4;
    bfi.b32     %r2, %r9, %r7, 22, 18;
    prmt.b32    %r3, %r4, %r2, 0x88b9;
    cvt.s32.u16 %r3, %r3;

    st.global.u32 [%rd1], %r3;
    ret;
}
