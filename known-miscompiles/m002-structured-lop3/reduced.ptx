.version 8.8
.target sm_103
.address_size 64

.entry fuzz_kernel(.param .u64 out_ptr)
{
    .reg .pred  %p<2>;
    .reg .b32   %r<9>;
    .reg .b64   %rd<6>;

    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r8, %tid.x;
    mov.u32         %r3, 1;
    mov.u32         %r7, 0;

label:
    setp.lt.s32   %p1, %r3, 15;
    selp.b32      %r0, %r3, %r7, %p1;
    lop3.b32      %r7, 26, %r0, %r0, 0x65;
    xor.b32       %r0, %r7, 26;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r8, 4;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4], %r0;
    ret;
}
