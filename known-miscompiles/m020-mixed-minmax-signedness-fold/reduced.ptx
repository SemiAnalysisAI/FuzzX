.version 8.8
.target sm_103
.address_size 64

.entry fuzz_kernel(.param .u64 out_ptr, .param .u32 n)
{
    .reg .b32 %r<5>;
    .reg .b64 %rd<1>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [n];

    shl.b32  %r1, %r0, 26;
    or.b32   %r1, %r1, 24;
    max.u32  %r2, 0, %r1;
    min.s32  %r3, %r2, 0;
    bfi.b32  %r4, %r3, 24, 5, 7;

    st.global.u32 [%rd0], %r4;
    ret;
}
