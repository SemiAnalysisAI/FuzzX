.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32   %r<22>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd0, [in_ptr];
    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r20, %tid.x;
    cvta.to.global.u64 %rd2, %rd0;
    mul.wide.u32    %rd3, %r20, 4;
    add.s64         %rd2, %rd2, %rd3;
    ld.global.u32   %r2, [%rd2];

    mov.u32         %r9, 33554432;
    mul.lo.u32      %r0, %r2, %r9;
    and.b32         %r1, 4278255360, %r20;
    mad.lo.u32      %r3, %r0, 16, %r1;
    sub.u32         %r1, 620912, %r3;
    mul.lo.u32      %r19, 524288, %r1;
    mul.lo.u32      %r0, %r19, %r19;
    or.b32          %r0, %r0, 55244;

exit:
    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.u32    %rd5, %r20, 16;
    add.s64         %rd4, %rd4, %rd5;
    st.global.u32   [%rd4 + 0], %r0;
    ret;
}
