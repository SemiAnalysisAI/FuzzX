.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .b32 %r<12>;
    .reg .b64 %rd<2>;

    ld.param.u64    %rd0, [out_ptr];
    ld.param.u32    %r0, [in_n];

    shl.b32         %r9, %r0, 1;
    shl.b32         %r9, %r9, 31;
    add.cc.u32      %r11, %r9, 536;
    addc.u32        %r9, 64, 0;

    cvta.to.global.u64 %rd1, %rd0;
    st.global.u32   [%rd1], %r9;
    ret;
}
