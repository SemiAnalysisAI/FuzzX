.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr
)
{
    .reg .b32 %r<1>;
    .reg .b64 %rd<2>;

    ld.param.u64    %rd0, [out_ptr];

    slct.s32.s32    %r0, 1, 12, 2142016040;

    cvta.to.global.u64 %rd1, %rd0;
    st.global.u32   [%rd1], %r0;
    ret;
}
