.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr,
    .param .u32 in_n
)
{
    .reg .pred %p<1>;
    .reg .b32 %r<3>;
    .reg .b64 %rd<1>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [in_n];
    mov.u32 %r1, 0;
x:
    shr.u32 %r1, %r1, 0;
    abs.s32 %r2, %r0;
    sub.u32 %r0, %r1, %r2;
    setp.lt.u32 %p0, %r1, %r0;
    selp.b32 %r0, 1, 2, %p0;
    st.global.u32 [%rd0], %r0;
    ret;
}
