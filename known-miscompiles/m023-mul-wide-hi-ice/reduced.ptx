.version 8.8
.target sm_103
.address_size 64

.entry fuzz_kernel(.param .u64 out_ptr, .param .u32 n)
{
    .reg .pred %p<1>;
    .reg .b32  %r<8>;
    .reg .b64  %rd<3>;

    ld.param.u64 %rd1, [out_ptr];
    ld.param.u32 %r0, [n];
    mov.u32      %r1, %tid.x;

    mul.wide.s32 %rd2, %r0, 0xffffffff;
    mov.b64      {%r4, %r5}, %rd2;
    mul.hi.s32   %r4, %r0, %r4;
    setp.ge.u32  %p0, %r4, %r1;
    selp.b32     %r7, 0xffffffa5, 0, %p0;

    st.global.u32 [%rd1], %r7;
    ret;
}
