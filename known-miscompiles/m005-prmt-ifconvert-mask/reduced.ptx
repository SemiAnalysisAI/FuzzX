.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 out_ptr,
    .param .u32 x,
    .param .u32 n
)
{
    .reg .pred %p<1>;
    .reg .b32 %r<3>;
    .reg .b64 %rd<1>;

    ld.param.u64 %rd0, [out_ptr];
    ld.param.u32 %r0, [x];
    ld.param.u32 %r1, [n];
    setp.ne.u32 %p0, %r1, 0;
    @%p0 bra then;
    mov.u32 %r2, 0;
    bra done;
then:
    prmt.b32 %r2, %r0, %r1, 0x9;
    and.b32 %r2, 255, %r2;
done:
    cvta.to.global.u64 %rd0, %rd0;
    st.global.u32 [%rd0], %r2;
    ret;
}
