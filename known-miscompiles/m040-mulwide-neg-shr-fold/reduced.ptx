.version 8.8
.target sm_103
.address_size 64

.visible .entry fuzz_kernel(
    .param .u64 in_ptr,
    .param .u64 out_ptr
)
{
    .reg .b32   %r<8>;
    .reg .b64   %rd<8>;

    ld.param.u64    %rd1, [out_ptr];
    mov.u32         %r0, %tid.x;

    mul.wide.u32  %rd2, %r0, %r0;
    mov.b64       {%r1, %r2}, %rd2;
    sub.u32       %r3, 0, %r1;
    shr.u32       %r4, %r3, 17;
    add.u32       %r5, %r4, 1;

    cvta.to.global.u64 %rd3, %rd1;
    cvt.u64.u32    %rd4, %r0;
    shl.b64        %rd4, %rd4, 4;
    add.s64        %rd3, %rd3, %rd4;
    st.global.u32  [%rd3], %r5;
    ret;
}
